---
import GitHub from "../icons/GitHub.astro";
import LinkedIn from "../icons/LinkedIn.astro";
import Layout from "../layouts/Layout.astro";
---

<Layout title="Mi Portafolio">
  <main>
	<section class="w-full mx-auto lg:w-[740px] py-44">
		<h1 class="text-7xl font-bold">Hola, soy Julián</h1>
		<h2 class="text-2xl font-medium">+1 año de experiencia en desarrollo web.</h2>
		<h2 class="text-2xl">Me especializo en crear interfaces de usuario atractivas y funcionales</h2>

		<ul class="flex gap-4">
			<li>
				<a href="https://www.linkedin.com/in/juliansanchezv/" target="_blank">
					<LinkedIn />
				</a>
			</li>
			<li>
				<a href="https://github.com/juliansanchezv" target="_blank">
					<GitHub />
				</a>
			</li>
		</ul>
	</section>
  </main>
</Layout>